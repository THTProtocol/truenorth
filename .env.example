# ═══════════════════════════════════════════════════════════════════════════════
# TrueNorth Environment Variables
# ═══════════════════════════════════════════════════════════════════════════════
# Copy to .env and fill in your values. NEVER commit .env to version control.

# ─── LLM API Keys ────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_AI_API_KEY=

# ─── Authentication ───────────────────────────────────────────────────────────
# When set, all web endpoints require Bearer token authentication.
# Generate with: openssl rand -hex 32
TRUENORTH_AUTH_TOKEN=

# ─── Logging ──────────────────────────────────────────────────────────────────
RUST_LOG=truenorth=info
TRUENORTH_LOG_LEVEL=info

# ─── Data Directory ──────────────────────────────────────────────────────────
TRUENORTH_DATA_DIR=./data
